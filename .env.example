# d1066-alert configuration — copy this file to `.env` and fill it in.
#   cp .env.example .env
# `.env` is git-ignored (it holds a personal phone number); never commit it.

# ── Required ────────────────────────────────────────────────────────────────

# Exact name of your iMessage group chat, as shown at the top of the conversation
# in Messages. The group MUST have a name set (Conversation → rename) or it can't
# be matched. Spaces are fine; no quotes needed.
GROUP_CHAT_NAME=Dragons of 1066

# ── Optional: outside player ────────────────────────────────────────────────
# If ONE player isn't in the group chat, they can get a private 1:1 reminder on their
# turn. Set their COLOR and PHONE to enable that (NAME is optional). Leave the color and
# phone blank (or delete the lines) if everyone is in the group chat — the bot then just
# posts the emoji to the group.

# One of: red, gold, blue, silver
OUTSIDE_PLAYER_COLOR=silver

# Full international format (leading +, country code, no spaces/dashes), e.g.
# +15551234567. An iMessage email also works here.
OUTSIDE_PLAYER_PHONE=+15551234567

# ── Optional: trigger words ────────────────────────────────────────────────
# What your group says to change turns. The trigger must be the entire message
# (case-insensitive; trailing punctuation like "red up!" is fine). Change these if
# your group uses different words.
TRIGGER_RED=red up
TRIGGER_GOLD=gold up
TRIGGER_BLUE=blue up
TRIGGER_SILVER=silver up

# ── Optional: timing (defaults shown) ───────────────────────────────────────

# How often the active player's reminder fires.
# Use a divisor of 60 for sub-hour (e.g. 15, 30) or a multiple of 60 for multi-hour
# (e.g. 120 = every 2 hours, 180 = every 3 hours). Other values fall back to 60.
REMINDER_INTERVAL_MINUTES=60

# How often to check the group chat for new trigger words.
POLL_INTERVAL_MINUTES=5

# ── Optional: AI replies ─────────────────────────────────────────────────────
# When an OpenAI API key is set, a turn change ALSO asks the model a question and
# posts its reply to the group chat (in addition to updating the turn + reminders).
# Leave OPENAI_API_KEY blank to disable this entirely — everything else still works.

# Your OpenAI API key (sk-...). Blank = AI replies off.
OPENAI_API_KEY=

# Model for the OpenAI Responses API. Defaults to gpt-5-mini if blank.
OPENAI_MODEL=gpt-5-mini

# The question asked on each turn change. Defaults to a "1+2=?" smoke test so you
# can confirm the trigger → OpenAI → iMessage path end-to-end before customizing it.
AI_PROMPT=1+2=?

# Set to false to keep the key configured but turn AI replies off. Defaults to true
# whenever OPENAI_API_KEY is set.
AI_ENABLED=true
